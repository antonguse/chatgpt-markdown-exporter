{
  "manifest_version": 3,
  "name": "GPT → Markdown",
  "version": "0.2.3",
  "description":  "Convert GPT chat to Markdown",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Convert GPT link to Markdown",
	"default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "host_permissions": [
    "https://chatgpt.com/*"
  ]
}
